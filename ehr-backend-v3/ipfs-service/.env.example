# Port this service listens on
PORT=3006

# Kubo IPFS API endpoint
# When running with docker-compose: http://ipfs.ehr.local:5001
# When running locally (dev):       http://localhost:5001
IPFS_API_URL=http://localhost:5001

# Optional: IPFS HTTP gateway for verification reads
IPFS_GATEWAY_URL=http://localhost:8090

# Max JSON body size accepted for pinning (bytes)
MAX_BODY_SIZE=5mb

# Internal API key — all other services must send this header:
#   X-IPFS-Key: <value>
# Prevents unauthorized direct access to this service.
IPFS_SERVICE_KEY=change-me-in-production
