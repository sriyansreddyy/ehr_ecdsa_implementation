# ── Key Vault (Supabase) ──────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ↑ Use the service_role key (under "Project API keys"), NOT the anon key.
#   The service_role key bypasses Row Level Security, which is what we want
#   since this runs server-side only and never reaches the browser.

# PBKDF2 iteration count for PIN → AES key derivation.
# 200000 is OWASP's 2023 recommendation for PBKDF2-SHA256.
# Higher = slower brute force, slower key fetch. Don't go below 100000.
VAULT_PBKDF2_ITERATIONS=200000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get API key from: https://resend.com → API Keys
# For local testing you can use: MAIL_FROM=onboarding@resend.dev
# For production, verify your domain in Resend and use your own address.


