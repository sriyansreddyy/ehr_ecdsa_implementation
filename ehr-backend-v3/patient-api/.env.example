# ── Server ────────────────────────────────────────────────────
PORT=3005
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# ── SQLite ────────────────────────────────────────────────────
# Path to SQLite database file (created automatically on first run)
SQLITE_PATH=./data/patients.db

# ── Fabric ────────────────────────────────────────────────────
# Base path of the ehr-network directory (where organizations/ lives)
FABRIC_BASE_PATH=../../../../ehr-network

# patientService identity — enrolled once in HospitalMSP
# This single account signs all patient-initiated blockchain transactions
PEER_ADDRESS=localhost:7051
FABRIC_CHANNEL=ehrchannel
FABRIC_CHAINCODE=ehr

# ── IPFS service ──────────────────────────────────────────────
IPFS_SERVICE_URL=http://localhost:3006
IPFS_SERVICE_KEY=change-me-in-production
