# =============================================================================
# EHR System — Hyperledger Fabric + IPFS
# =============================================================================

# =============================================================================
# CREDENTIALS & SECRETS — NEVER COMMIT THESE
# =============================================================================

# Environment files
.env
.env.*
!.env.example
!.env.sys2
!.env.sys3

# JWT secrets, API keys
*.secret
*.secrets
secrets/

# bcrypt hashes / credential store
shared/users.json

# SQLite patient database (contains bcrypt hashes)
*.db
*.db-shm
*.db-wal
data/patients.db
data/

# =============================================================================
# HYPERLEDGER FABRIC CRYPTO MATERIAL — NEVER COMMIT PRIVATE KEYS
# =============================================================================

# Private keys — the most critical files to exclude
**/keystore/*_sk
**/keystore/IssuerRevocationPrivateKey
**/keystore/IssuerSecretKey
**/*_sk
**/*.key

# TLS private keys
**/tls/server.key
**/tls/keystore/

# Fabric CA server databases (contain internal CA state + private material)
**/fabric-ca-server.db

# Enrolled user MSP directories (contain private keys)
organizations/peerOrganizations/*/users/*/msp/keystore/
organizations/ordererOrganizations/*/users/*/msp/keystore/
organizations/ordererOrganizations/*/orderers/*/msp/keystore/
organizations/peerOrganizations/*/peers/*/msp/keystore/
organizations/peerOrganizations/*/peers/*/tls/keystore/
organizations/ordererOrganizations/*/orderers/*/tls/keystore/

# =============================================================================
# NODE.JS
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json

# =============================================================================
# LOGS
# =============================================================================

logs/
*.log
api.log
error.log

# =============================================================================
# HYPERLEDGER FABRIC GENERATED ARTIFACTS
# =============================================================================

# Channel artifacts (regenerated by createChannel.sh)
channel-artifacts/*.block
channel-artifacts/*.pb
channel-artifacts/*.json
channel-artifacts/*.tx

# Packaged chaincode (regenerated by deployChaincode.sh)
*.tar.gz

# Ledger dumps (generated by dump_ledger.sh / ehr_explorer.sh)
ledger_dump/
block_*.json
block_*.pb

# Temporary configtxlator / osnadmin output
/tmp/*.pb
/tmp/*.json

# =============================================================================
# IPFS
# =============================================================================

# Local IPFS repo (contains node private key and datastore)
.ipfs/
ipfs-data/

# =============================================================================
# FRONTEND BUILD OUTPUT
# =============================================================================

dist/
build/
.vite/
.next/
out/

# =============================================================================
# OS FILES
# =============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# =============================================================================
# EDITOR / IDE
# =============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# =============================================================================
# MISC
# =============================================================================

coverage/
.nyc_output/
tmp/
temp/
*.tmp
*.bak
*.orig
